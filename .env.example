# ============================================================
# YouTube Shorts OS — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...        # Choose a calm, authoritative male or female voice

# --- YouTube Data API ---
# OAuth2 credentials JSON path (download from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_PATH=config/client_secrets.json
YOUTUBE_TOKEN_PATH=config/youtube_token.json
YOUTUBE_CHANNEL_ID=UC...

# --- Pexels API (B-roll footage, free commercial license) ---
PEXELS_API_KEY=...

# --- Pixabay API (fallback B-roll, free commercial license) ---
PIXABAY_API_KEY=...

# --- Database ---
DATABASE_PATH=data/shorts_os.db

# --- Paths ---
OUTPUT_DIR=output                # Rendered videos land here before upload
ASSETS_DIR=data/assets           # Audio, subtitles, scene files
TEMPLATES_DIR=modules/render/templates

# --- Pipeline Behavior ---
PUBLISH_MODE=manual              # manual | auto
                                 # manual = queue videos, human clicks publish
                                 # auto   = auto-upload on schedule
DAILY_VIDEO_TARGET=2
IDEA_BACKLOG_MIN=14              # Trigger research run if backlog drops below this
HUMAN_REVIEW_SCRIPTS=true        # Pause pipeline for human sign-off before render
HUMAN_REVIEW_VIDEOS=true         # Pause pipeline for human sign-off before upload

# --- Scheduling ---
RESEARCH_CRON=0 6 * * 1          # Weekly Monday 6am
PRODUCTION_CRON=0 7 * * *        # Daily 7am — generate scripts + render
PUBLISH_CRON=0 9,17 * * *        # Daily 9am and 5pm uploads
ANALYTICS_CRON=0 8 * * *         # Daily 8am — ingest previous day's data

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
